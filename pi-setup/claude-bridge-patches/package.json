{
  "name": "pi-claude-bridge",
  "version": "0.3.1",
  "private": false,
  "description": "Pi extension that uses Claude Code (via Agent SDK) as a model provider and adds an AskClaude tool.",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "claude-code",
    "claude-agent-sdk"
  ],
  "author": "Eli Dickinson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elidickinson/pi-claude-bridge.git"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "index.ts",
    "convert.ts",
    "models.ts",
    "skills.ts",
    "session-verify.ts",
    "extract-tool-results.ts",
    "query-state.ts",
    "README.md",
    "LICENSE",
    "claude-bridge1.png",
    "claude-bridge2.png"
  ],
  "scripts": {
    "test:unit": "node --import tsx --test tests/unit-*.mjs",
    "test": "set -a && [ -f .env.test ] && . .env.test; set +a && npm run test:unit && tests/int-smoke.sh && tests/int-multi-turn.sh && tests/int-cache.sh && node --import tsx --test tests/int-*.mjs",
    "test:usage": "tests/usage-test.sh",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@anthropic-ai/sdk": "^0.73.0",
    "cc-session-io": "^0.3.1",
    "change-case": "^5.4.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.67.6",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@types/node": "^24.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
