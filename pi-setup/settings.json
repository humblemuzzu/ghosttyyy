  "steeringMode": "all",
  "followUpMode": "all",
  "doubleEscapeAction": "tree",
  "quietStartup": true,
  "packages": [
    "npm:pi-web-access",
    "npm:pi-context",
    "npm:pi-token-burden",
    "npm:@benvargas/pi-claude-code-use",
    "npm:@marckrenn/pi-sub-bar",
    "https://github.com/davebcn87/pi-autoresearch",
    "npm:@sting8k/pi-vcc",
    "npm:pi-tool-display",
    "npm:@tomooshi/condensed-milk-pi",
    "https://github.com/edxeth/pi-gpt-config",
    "https://github.com/injaneity/pi-computer-use@v0.2.1",
    "https://github.com/eko24ive/pi-ask"
  ],
  "terminal": {
    "clearOnShrink": true
  }
}